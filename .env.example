# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GDPR / Privacy modal ────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVACY_CONTROLLER=
NEXT_PUBLIC_PRIVACY_EMAIL=

# ── Sentry (optional — error tracking) ──────────────────────────────────────
# Without a DSN, Sentry init is a no-op. To enable, set:
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=                    # e.g. production / staging
# Server-only (build-time source map upload — both must be set to enable):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PostHog (optional — product analytics) ──────────────────────────────────
# Without a key, all track() calls are no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Upstash Redis (optional — API rate limiting) ────────────────────────────
# Without these, rateLimit() falls open. Free tier: 10k cmd/day.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Web Push / VAPID (optional — PWA push notifications) ─────────────────────
# Generate a keypair: `node -e "console.log(require('web-push').generateVAPIDKeys())"`
# Without these, push is a no-op (in-app realtime notifications still work).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Cron — protects scheduled jobs (e.g. session-end reminders) ──────────────
# Required for /api/cron/* routes. Vercel cron auto-sends this as
# `Authorization: Bearer ${CRON_SECRET}` when CRON_SECRET is set in the
# project env. Without it the cron route refuses every request.
# Note: vercel.json schedules /api/cron/session-reminders every minute —
# requires Vercel Pro (Hobby supports only daily). Alternative: a Supabase
# pg_cron + pg_net job hitting the same URL with the same Bearer header.
CRON_SECRET=
