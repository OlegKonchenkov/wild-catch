# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GDPR / Privacy modal ────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVACY_CONTROLLER=
NEXT_PUBLIC_PRIVACY_EMAIL=

# ── Sentry (optional — error tracking) ──────────────────────────────────────
# Without a DSN, Sentry init is a no-op. To enable, set:
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=                    # e.g. production / staging
# Server-only (build-time source map upload — both must be set to enable):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PostHog (optional — product analytics) ──────────────────────────────────
# Without a key, all track() calls are no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Upstash Redis (optional — API rate limiting) ────────────────────────────
# Without these, rateLimit() falls open. Free tier: 10k cmd/day.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
