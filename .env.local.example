# ============================================================
# WildCatch — variabili d'ambiente
# Copia questo file in .env.local e compila i valori
# ============================================================

# --- SUPABASE (obbligatorio) ---
# Trovi questi valori in: Supabase Dashboard → Project Settings → API

# URL del progetto (es. https://abcxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chiave pubblica "anon" (sicura da esporre nel browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chiave "service_role" (SEGRETA — solo server, mai nel browser)
# Usata da createAdminClient() per bypassare RLS
SUPABASE_SERVICE_ROLE_KEY=

# --- SUPABASE CLI (per npx supabase db push) ---
# Trovi questi in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- URL PUBBLICA APP ---
# In locale: http://localhost:3000
# In produzione: https://wildcatch.vercel.app (o il tuo dominio)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- DA CONFIGURARE NELLA DASHBOARD SUPABASE (non sono variabili env) ---
# Authentication → URL Configuration:
#   Site URL:        https://wildcatch.vercel.app
#   Redirect URLs:   https://wildcatch.vercel.app/auth/callback
#
# Authentication → Providers → Google:
#   Client ID:       (da Google Cloud Console → Credenziali → OAuth 2.0)
#   Client Secret:   (da Google Cloud Console → Credenziali → OAuth 2.0)
